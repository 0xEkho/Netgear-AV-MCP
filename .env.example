# Copy this file to .env and fill in the values
# cp .env.example .env
# WARNING: Never commit .env to version control

# ---------------------------------------------------------------------------
# MCP Server
# ---------------------------------------------------------------------------
MCP_SERVER_NAME=netgear-av-mcp
MCP_SERVER_VERSION=1.0.0
MCP_TRANSPORT=streamable-http
MCP_HOST=0.0.0.0
MCP_PORT=8080

# ---------------------------------------------------------------------------
# MCP Security
# ---------------------------------------------------------------------------
MCP_API_KEY=
MCP_ALLOWED_IPS=127.0.0.1/32,10.0.0.0/8,192.168.0.0/16

# ---------------------------------------------------------------------------
# SSH Global Credentials
# ---------------------------------------------------------------------------
NETGEAR_GLOBAL_USERNAME=admin
NETGEAR_GLOBAL_PASSWORD=

# ---------------------------------------------------------------------------
# SSH Zone Fallback Credentials (10.X.0.0/16)
# ---------------------------------------------------------------------------
# NETGEAR_ZONE1_USERNAME=
# NETGEAR_ZONE1_PASSWORD=
# NETGEAR_ZONE9_USERNAME=
# NETGEAR_ZONE9_PASSWORD=

# ---------------------------------------------------------------------------
# SSH Settings
# ---------------------------------------------------------------------------
SSH_STRICT_HOST_KEY=false
SSH_KNOWN_HOSTS_FILE=./known_hosts
SSH_CONNECT_TIMEOUT=10
SSH_COMMAND_TIMEOUT=30

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
